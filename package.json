{
    "name": "coquo",
    "version": "1.2.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "nodemon -e ts --watch server -x tsx server/index.ts",
        "build": "prisma generate && BETTER_AUTH_SECRET=build-placeholder-not-used-at-runtime next build && tsc -p tsconfig.server.json",
        "start": "NODE_ENV=production node dist/server/index.js",
        "db:reset": "npx prisma migrate reset",
        "db:seed": "npx prisma db seed",
        "db:push": "npx prisma db push",
        "db:pull": "npx prisma db pull",
        "db:studio": "npx prisma studio",
        "db:migrate": "npx prisma migrate dev --name",
        "docker:build": "docker build -t coquo ."
    },
    "dependencies": {
