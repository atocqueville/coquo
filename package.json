{
    "name": "coquo",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev:start": "npx pm2 start ecosystem.dev.config.js",
        "dev:stop": "npx pm2 stop ecosystem.dev.config.js",
        "dev:status": "npx pm2 status",
        "prisma:reset": "npx dotenv -e .env.local -- prisma migrate reset",
        "prisma:migrate": "npx dotenv -e .env.local -- prisma migrate dev --name",
        "db:seed": "npx dotenv -e .env.local -- prisma db seed",
        "db:push": "npx dotenv -e .env.local -- prisma db push",
        "db:pull": "npx dotenv -e .env.local -- prisma db pull",
        "build:prod": "prisma generate && next build",
        "docker:build": "docker build -t coquo ."
    },
    "dependencies": {
